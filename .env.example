# API mode: "mock" runs locally without any backend; "real" hits the n8n webhooks below.
VITE_API_MODE=mock

# Base URL for your n8n instance (no trailing slash), e.g. https://n8n.example.com/webhook
VITE_N8N_BASE_URL=

# Paths appended to VITE_N8N_BASE_URL for each operation
VITE_N8N_GENERATE_TITLES_PATH=/generate-titles
VITE_N8N_GENERATE_ARTICLE_PATH=/generate-article
VITE_N8N_PUBLISH_PATH=/publish

# ---------------------------------------------------------------------------
# Supabase auth (required for both mock and real mode — the app is gated)
# ---------------------------------------------------------------------------
# Project URL, e.g. https://your-project.supabase.co
VITE_SUPABASE_URL=

# Anon (public) key — safe to expose to the browser. Get it from
# Supabase dashboard → Project Settings → API → "anon public" key.
VITE_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# FA Deals Automation webhooks (full URLs to the n8n cloud endpoints)
# ---------------------------------------------------------------------------
# Both required only when VITE_API_MODE=real. In mock mode the deals
# feature uses local sample data instead.
VITE_ENRICH_DEAL_URL=https://onechancemedia.app.n8n.cloud/webhook/enrich-deal
VITE_POST_DEAL_URL=https://onechancemedia.app.n8n.cloud/webhook/post-deal
